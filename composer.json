{
    "name": "fissible/attest",
    "description": "Tamper-evident signed evidence chains for application events, with optional public anchoring via OpenTimestamps.",
    "type": "library",
    "license": "MIT",
    "keywords": ["audit", "audit-log", "tamper-evident", "evidence", "ed25519", "opentimestamps", "merkle"],
    "authors": [
        {"name": "Allen McCabe", "email": "allenmccabe@gmail.com"}
    ],
    "require": {
        "php": "^8.2",
        "ext-sodium": "*",
        "ext-zip": "*",
        "ext-json": "*",
        "paragonie/constant_time_encoding": "^2.6 || ^3.0",
        "symfony/uid": "^6.4 || ^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {"Fissible\\Attest\\": "src/"}
    },
    "autoload-dev": {
        "psr-4": {"Fissible\\Attest\\Tests\\": "tests/"}
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
